---
import Layout from '../layouts/Layout.astro';

const brands = [
  { name: 'Classy Llama',      category: 'Agency'    },
  { name: 'B2W Digital',       category: 'E-commerce'},
  { name: 'Sephora',           category: 'Beauty'    },
  { name: 'TIM',               category: 'Telecom'   },
  { name: 'MagedIn Technology',category: 'Tech'      },
  { name: 'Livraria Saraiva',  category: 'Retail'    },
  { name: 'John John',         category: 'Fashion'   },
  { name: 'Lelis Blanc',       category: 'Fashion'   },
  { name: 'McFadyen Digital',  category: 'Agency'    },
  { name: 'GRAYBOX',           category: 'Agency'    },
];
---

<Layout title="Tiago Sampaio — E-Commerce Architect">

  <!-- ░░ HERO ░░ -->
  <section class="hero">
    <div class="hero-bg">
      <div class="hero-img-placeholder">
        <!-- Replace src with your photo: <img src="/images/hero.jpg" alt="" class="hero-photo" /> -->
      </div>
      <div class="hero-overlay"></div>
      <div class="hero-vignette"></div>
      <div class="hero-grid"></div>
      <div class="hero-orb"></div>
    </div>

    <div class="hero-content container">
      <div class="hero-eyebrow">
        <span class="pulse-dot"></span>
        Available for consulting
      </div>

      <h1 class="hero-title">
        <span class="hero-title__serif">Crafting</span>
        <span class="hero-title__big">Commerce</span>
        <span class="hero-title__italic">at scale.</span>
      </h1>

      <p class="hero-sub">
        Adobe Certified Expert &amp; Technical Lead at Classy Llama.<br />
        15+ years. Founder of MagedIn Technology. Built for scale.
      </p>

      <div class="hero-actions">
        <a href="/work" class="btn btn-primary">
          <svg width="16" height="16" viewBox="0 0 16 16" fill="none">
            <path d="M3 8h10M9 4l4 4-4 4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
          View My Work
        </a>
        <a href="/about" class="btn btn-outline">About Me</a>
      </div>
    </div>

    <div class="hero-scroll">
      <span>Scroll</span>
      <div class="hero-scroll__line"></div>
    </div>

    <div class="hero-badge">
      <span class="hero-badge__num">15+</span>
      <span class="hero-badge__label">Years of<br/>Excellence</span>
    </div>
  </section>

  <!-- ░░ MARQUEE BRANDS ░░ -->
  <section class="marquee-section">
    <div class="marquee-label">Trusted by</div>
    <div class="marquee-track-wrapper">
      <div class="marquee-track">
        {[...brands, ...brands].map(b => (
          <div class="marquee-item">
            <span class="marquee-name">{b.name}</span>
            <span class="marquee-sep">·</span>
            <span class="marquee-cat">{b.category}</span>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ░░ INTRO STATEMENT ░░ -->
  <section class="intro">
    <div class="container">
      <div class="intro-grid">
        <div class="intro-left" data-reveal="left">
          <div class="section-eyebrow">What I do</div>
          <h2 class="display-title">
            I build the commerce<br/>
            infrastructure that<br/>
            <em>powers great brands.</em>
          </h2>
        </div>
        <div class="intro-right">
          <p class="body-lead" data-reveal data-delay="2">
            Adobe Certified Expert with 15+ years in Magento and e-commerce.
            Currently Technical Lead at Classy Llama (US) and founder of
            MagedIn Technology — I've architected solutions for some of
            Brazil's biggest digital commerce operations.
          </p>
          <p class="body-lead" data-reveal data-delay="3" style="margin-top: 20px;">
            From managing technology at B2W Digital — Brazil's largest
            e-commerce group — to leading enterprise Magento projects for
            global agencies, I bring both depth and breadth to every engagement.
          </p>
          <div class="intro-stats">
            <div class="istat" data-reveal data-delay="3">
              <span class="istat-num">50<sup>+</sup></span>
              <span class="istat-label">Projects Delivered</span>
            </div>
            <div class="istat" data-reveal data-delay="4">
              <span class="istat-num">20<sup>+</sup></span>
              <span class="istat-label">Global Brands</span>
            </div>
            <div class="istat" data-reveal data-delay="5">
              <span class="istat-num">15<sup>+</sup></span>
              <span class="istat-label">Years Experience</span>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ░░ FEATURED IMAGE STRIP ░░ -->
  <section class="image-strip">
    <div class="strip-grid">
      <div class="strip-cell strip-cell--tall" data-reveal>
        <div class="strip-img strip-img--1">
          <!-- <img src="/images/photo-1.jpg" alt="Tiago Sampaio" /> -->
          <div class="strip-placeholder">
            <span class="strip-placeholder__label">Your photo here</span>
          </div>
        </div>
        <div class="strip-caption">Architecture & Code</div>
      </div>
      <div class="strip-cell strip-cell--right" data-reveal data-delay="2">
        <div class="strip-img strip-img--2">
          <div class="strip-placeholder">
            <span class="strip-placeholder__label">Working photo</span>
          </div>
        </div>
        <div class="strip-img strip-img--3">
          <div class="strip-placeholder">
            <span class="strip-placeholder__label">Event / speaking</span>
          </div>
        </div>
      </div>
      <div class="strip-cell strip-cell--quote" data-reveal data-delay="3">
        <blockquote class="strip-quote">
          "Commerce is not just about transactions — it's about crafting an experience that earns trust at scale."
          <cite>— Tiago Sampaio</cite>
        </blockquote>
      </div>
    </div>
  </section>

  <!-- ░░ EXPERTISE TEASER ░░ -->
  <section class="expertise-teaser">
    <div class="container">
      <div class="section-eyebrow" data-reveal>Core Expertise</div>
      <div class="expertise-list">
        {[
          { num: '01', title: 'Adobe Commerce / Magento 2', desc: 'Deep-platform mastery — custom modules, architecture, performance tuning, and multi-store ecosystems.' },
          { num: '02', title: 'Backend Architecture',        desc: 'PHP 8, SOLID principles, clean code, event-driven systems, REST & GraphQL APIs at scale.' },
          { num: '03', title: 'Cloud & Infrastructure',      desc: 'Adobe Commerce Cloud, AWS, Docker, CI/CD pipelines, and high-availability configurations.' },
          { num: '04', title: 'Systems Integration',         desc: 'ERP, CRM, PIM, payment gateways, logistics, and marketing automation — wired together seamlessly.' },
        ].map((item, i) => (
          <div class="etile" data-reveal data-delay={String(i + 1)}>
            <span class="etile-num">{item.num}</span>
            <h3 class="etile-title">{item.title}</h3>
            <p class="etile-desc">{item.desc}</p>
          </div>
        ))}
      </div>
      <div class="expertise-cta" data-reveal>
        <a href="/work" class="btn btn-outline">See All Projects →</a>
      </div>
    </div>
  </section>

  <!-- ░░ CERTIFICATION ░░ -->
  <section class="cert-section">
    <div class="container">
      <div class="cert-inner" data-reveal>
        <div class="cert-badge-wrap">
          <a href="https://certification.adobe.com/credential/verify/017dbbf4-5e7b-11f1-be16-42010a400fe2" target="_blank" rel="noopener" class="cert-badge-link">
            <img
              src="/images/017dbbf4-5e7b-11f1-be16-42010a400fe2_badge.png"
              alt="Adobe Certified Expert — Adobe Commerce Developer"
              class="cert-badge-img"
            />
            <span class="cert-badge-verify">
              <svg width="12" height="12" viewBox="0 0 12 12" fill="none"><path d="M10 3L5 8.5 2 5.5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
              Verify credential
            </span>
          </a>
        </div>

        <div class="cert-copy">
          <div class="section-eyebrow">Adobe Certified Expert</div>
          <h2 class="cert-title">
            Certified expertise<br/>
            <em>you can trust.</em>
          </h2>
          <p class="cert-desc">
            Adobe Commerce certification isn't handed out — it demands deep, proven mastery
            of the platform's architecture, development patterns, and best practices.
            Working with a certified professional means your project is built on solid
            foundations: less technical debt, fewer costly mistakes, and a platform
            designed to grow with your business.
          </p>
          <ul class="cert-points">
            <li>
              <span class="cert-point-icon">✦</span>
              <span>Architecture decisions grounded in platform standards, not guesswork</span>
            </li>
            <li>
              <span class="cert-point-icon">✦</span>
              <span>Code that Adobe's own guidelines would approve — maintainable and upgrade-safe</span>
            </li>
            <li>
              <span class="cert-point-icon">✦</span>
              <span>Performance, security, and scalability treated as first-class requirements</span>
            </li>
          </ul>
          <a href="https://certification.adobe.com/credential/verify/017dbbf4-5e7b-11f1-be16-42010a400fe2" target="_blank" rel="noopener" class="btn btn-outline cert-btn">
            Verify My Certification ↗
          </a>
        </div>
      </div>
    </div>
  </section>

  <!-- ░░ CTA BAND ░░ -->
  <section class="cta-band">
    <div class="cta-band__glow"></div>
    <div class="container">
      <div class="cta-band__inner" data-reveal>
        <h2 class="display-title cta-band__title">
          Ready to build something<br/><em>extraordinary?</em>
        </h2>
        <a href="/contact" class="btn btn-primary">Start the Conversation</a>
      </div>
    </div>
  </section>

</Layout>

<style>
/* HERO */
.hero {
  position: relative;
  min-height: 100vh;
  display: flex;
  align-items: center;
  overflow: hidden;
}
.hero-bg { position: absolute; inset: 0; }
.hero-img-placeholder {
  position: absolute; inset: 0;
  background:
    radial-gradient(ellipse 70% 70% at 65% 40%, rgba(124,111,255,0.08) 0%, transparent 60%),
    linear-gradient(180deg, #06080f 0%, #0c0f1e 50%, #06080f 100%);
}
.hero-overlay {
  position: absolute; inset: 0;
  background: linear-gradient(105deg,
    rgba(6,8,15,0.97) 0%,
    rgba(6,8,15,0.82) 50%,
    rgba(6,8,15,0.5) 100%
  );
}
.hero-vignette {
  position: absolute; inset: 0;
  background: radial-gradient(ellipse 120% 100% at 50% 100%, rgba(6,8,15,0.9) 0%, transparent 60%);
}
.hero-grid {
  position: absolute; inset: 0;
  background-image:
    linear-gradient(rgba(124,111,255,0.04) 1px, transparent 1px),
    linear-gradient(90deg, rgba(124,111,255,0.04) 1px, transparent 1px);
  background-size: 80px 80px;
  mask-image: radial-gradient(ellipse 60% 80% at 60% 40%, black, transparent);
}
.hero-orb {
  position: absolute;
  width: 700px; height: 700px;
  right: -100px; top: -150px;
  background: radial-gradient(circle, rgba(124,111,255,0.12) 0%, transparent 65%);
  filter: blur(60px);
  pointer-events: none;
}
.hero-photo {
  position: absolute; inset: 0;
  width: 100%; height: 100%;
  object-fit: cover;
  object-position: center top;
}
.hero-content {
  position: relative;
  z-index: 1;
  padding-top: var(--nav-h);
}
.hero-eyebrow {
  display: inline-flex;
  align-items: center;
  gap: 10px;
  background: rgba(124,111,255,0.1);
  border: 1px solid rgba(124,111,255,0.25);
  color: var(--accent-2);
  padding: 8px 18px;
  border-radius: 100px;
  font-size: 0.78rem;
  font-weight: 500;
  letter-spacing: 0.06em;
  margin-bottom: 40px;
  animation: fadeUp 0.8s var(--ease-out-expo) 0.1s both;
}
.pulse-dot {
  width: 7px; height: 7px;
  background: #22c55e; border-radius: 50%;
  box-shadow: 0 0 8px #22c55e;
  animation: pulse 2s infinite;
}
@keyframes pulse { 0%,100%{opacity:1} 50%{opacity:.35} }
.hero-title {
  display: flex;
  flex-direction: column;
  margin-bottom: 36px;
  animation: fadeUp 0.8s var(--ease-out-expo) 0.2s both;
}
.hero-title__serif {
  font-family: var(--font-display);
  font-size: clamp(1.6rem, 3vw, 2.8rem);
  font-weight: 400;
  font-style: italic;
  color: var(--text-2);
  line-height: 1.2;
}
.hero-title__big {
  font-size: clamp(4.5rem, 11vw, 9.5rem);
  font-weight: 900;
  letter-spacing: -0.045em;
  line-height: 0.88;
  background: linear-gradient(160deg, #fff 20%, rgba(255,255,255,0.5) 100%);
  -webkit-background-clip: text;
  -webkit-text-fill-color: transparent;
  background-clip: text;
}
.hero-title__italic {
  font-family: var(--font-display);
  font-size: clamp(2rem, 5.5vw, 5rem);
  font-weight: 700;
  font-style: italic;
  color: var(--accent-2);
  letter-spacing: -0.02em;
  line-height: 1.1;
  margin-top: 8px;
}
.hero-sub {
  font-size: clamp(0.9rem, 1.6vw, 1.05rem);
  color: var(--text-2);
  line-height: 1.75;
  max-width: 420px;
  margin-bottom: 44px;
  animation: fadeUp 0.8s var(--ease-out-expo) 0.35s both;
}
.hero-actions {
  display: flex; gap: 14px; flex-wrap: wrap;
  animation: fadeUp 0.8s var(--ease-out-expo) 0.45s both;
}
.hero-scroll {
  position: absolute; bottom: 40px; left: 50%;
  transform: translateX(-50%);
  display: flex; flex-direction: column; align-items: center; gap: 10px;
  color: var(--text-3);
  font-size: 0.62rem; letter-spacing: 0.18em; text-transform: uppercase;
  font-family: var(--mono); z-index: 1;
  animation: fadeUp 1s var(--ease-out-expo) 0.8s both;
}
.hero-scroll__line {
  width: 1px; height: 48px;
  background: linear-gradient(to bottom, var(--text-3), transparent);
  animation: scrollDrop 2.4s ease-in-out infinite;
}
@keyframes scrollDrop {
  0%   { transform: scaleY(0); transform-origin: top; }
  45%  { transform: scaleY(1); transform-origin: top; }
  55%  { transform: scaleY(1); transform-origin: bottom; }
  100% { transform: scaleY(0); transform-origin: bottom; }
}
.hero-badge {
  position: absolute; bottom: 60px; right: 48px;
  text-align: right; z-index: 1;
  animation: fadeUp 0.8s var(--ease-out-expo) 0.6s both;
}
.hero-badge__num {
  display: block; font-size: 3.2rem; font-weight: 900;
  letter-spacing: -0.04em; color: var(--text); line-height: 1;
}
.hero-badge__label {
  font-size: 0.68rem; color: var(--text-3);
  letter-spacing: 0.1em; text-transform: uppercase; font-family: var(--mono);
  line-height: 1.6;
}
@keyframes fadeUp { from{opacity:0;transform:translateY(24px)} to{opacity:1;transform:none} }

/* MARQUEE */
.marquee-section {
  border-top: 1px solid var(--border);
  border-bottom: 1px solid var(--border);
  padding: 28px 0;
  overflow: hidden;
  display: flex;
  align-items: center;
  gap: 40px;
}
.marquee-label {
  flex-shrink: 0; padding-left: 32px;
  font-family: var(--mono); font-size: 11px;
  letter-spacing: 0.15em; text-transform: uppercase; color: var(--text-3);
  white-space: nowrap;
}
.marquee-track-wrapper {
  flex: 1; overflow: hidden;
  mask-image: linear-gradient(90deg, transparent, black 5%, black 95%, transparent);
}
.marquee-track {
  display: flex; width: max-content;
  animation: marquee 28s linear infinite;
}
.marquee-track:hover { animation-play-state: paused; }
@keyframes marquee { from{transform:translateX(0)} to{transform:translateX(-50%)} }
.marquee-item {
  display: flex; align-items: center; gap: 10px;
  padding: 0 40px; border-right: 1px solid var(--border); white-space: nowrap;
}
.marquee-name { font-size: 0.9rem; font-weight: 600; color: var(--text-2); }
.marquee-sep  { color: var(--text-3); }
.marquee-cat  { font-size: 0.7rem; font-family: var(--mono); color: var(--text-3); }

/* INTRO */
.intro { padding: 140px 0; }
.intro-grid {
  display: grid; grid-template-columns: 1fr 1fr;
  gap: 80px; align-items: start;
}
.intro-stats {
  display: flex; gap: 40px;
  margin-top: 48px; padding-top: 40px;
  border-top: 1px solid var(--border);
}
.istat-num {
  display: block; font-size: 2.5rem; font-weight: 900;
  letter-spacing: -0.03em; line-height: 1; color: var(--text); margin-bottom: 6px;
}
.istat-num sup { font-size: 1.2rem; color: var(--accent); vertical-align: super; }
.istat-label {
  font-size: 0.68rem; color: var(--text-3);
  letter-spacing: 0.1em; text-transform: uppercase; font-family: var(--mono);
}

/* IMAGE STRIP */
.image-strip { padding: 0 0 120px; }
.strip-grid {
  display: grid; grid-template-columns: 1.2fr 1fr 0.8fr;
  gap: 16px; padding: 0 32px;
  max-width: 1200px; margin: 0 auto;
  min-height: 560px;
}
.strip-cell { display: flex; flex-direction: column; gap: 16px; }
.strip-cell--right { gap: 16px; }
.strip-img {
  border-radius: var(--radius); overflow: hidden; position: relative;
  background: var(--bg-surface); border: 1px solid var(--border);
  min-height: 180px;
}
.strip-img--1 { flex: 1; }
.strip-img--2 { flex: 0 0 52%; }
.strip-img--3 { flex: 1; }
.strip-placeholder {
  position: absolute; inset: 0;
  display: flex; align-items: center; justify-content: center;
  background: linear-gradient(135deg, rgba(124,111,255,0.06) 0%, transparent 60%);
}
.strip-placeholder__label {
  font-family: var(--mono); font-size: 0.68rem; color: var(--text-3);
  letter-spacing: 0.1em; text-transform: uppercase;
  border: 1px dashed rgba(124,111,255,0.3);
  padding: 8px 14px; border-radius: 4px;
}
.strip-caption {
  font-family: var(--mono); font-size: 0.68rem; color: var(--text-3);
  letter-spacing: 0.1em; text-transform: uppercase;
}
.strip-cell--quote {
  display: flex; align-items: center; justify-content: center;
  padding: 40px 28px;
  background: var(--bg-surface); border: 1px solid var(--border);
  border-radius: var(--radius);
}
.strip-quote {
  font-family: var(--font-display); font-size: 1.25rem;
  font-style: italic; color: var(--text-2); line-height: 1.65;
}
.strip-quote cite {
  display: block; margin-top: 20px; font-size: 0.72rem;
  font-family: var(--mono); font-style: normal; color: var(--accent);
  letter-spacing: 0.08em;
}

/* EXPERTISE TEASER */
.expertise-teaser { padding: 80px 0 120px; }
.expertise-list {
  display: grid; grid-template-columns: repeat(4,1fr);
  gap: 1px; background: var(--border);
  border: 1px solid var(--border); border-radius: var(--radius);
  overflow: hidden; margin: 48px 0;
}
.etile { background: var(--bg); padding: 40px 32px; transition: background 0.3s; }
.etile:hover { background: var(--bg-surface); }
.etile-num {
  font-family: var(--mono); font-size: 0.72rem; color: var(--accent);
  letter-spacing: 0.1em; display: block; margin-bottom: 20px;
}
.etile-title { font-size: 1rem; font-weight: 700; margin-bottom: 12px; color: var(--text); line-height: 1.3; }
.etile-desc  { font-size: 0.85rem; color: var(--text-2); line-height: 1.7; }
.expertise-cta { text-align: center; }

/* CERTIFICATION */
.cert-section {
  padding: 80px 0 120px;
  border-top: 1px solid var(--border);
}
.cert-inner {
  display: grid;
  grid-template-columns: 280px 1fr;
  gap: 80px;
  align-items: center;
}
.cert-badge-wrap {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 16px;
}
.cert-badge-link {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 12px;
  text-decoration: none;
  transition: transform 0.3s;
}
.cert-badge-link:hover { transform: translateY(-4px); }
.cert-badge-img {
  width: 220px;
  height: auto;
  filter: drop-shadow(0 0 32px rgba(124,111,255,0.25));
}
.cert-badge-verify {
  display: inline-flex;
  align-items: center;
  gap: 6px;
  font-family: var(--mono);
  font-size: 0.68rem;
  color: var(--accent-2);
  letter-spacing: 0.08em;
  text-transform: uppercase;
  border: 1px solid rgba(124,111,255,0.25);
  padding: 6px 14px;
  border-radius: 100px;
  background: rgba(124,111,255,0.06);
}
.cert-title {
  font-size: clamp(2rem, 3.5vw, 3rem);
  font-weight: 800;
  letter-spacing: -0.03em;
  line-height: 1.15;
  color: var(--text);
  margin: 16px 0 24px;
}
.cert-title em {
  font-family: var(--font-display);
  font-style: italic;
  color: var(--accent-2);
}
.cert-desc {
  font-size: 0.95rem;
  color: var(--text-2);
  line-height: 1.8;
  margin-bottom: 28px;
  max-width: 580px;
}
.cert-points {
  display: flex;
  flex-direction: column;
  gap: 14px;
  margin-bottom: 36px;
  list-style: none;
}
.cert-points li {
  display: flex;
  gap: 12px;
  font-size: 0.9rem;
  color: var(--text-2);
  line-height: 1.6;
}
.cert-point-icon {
  color: var(--accent);
  font-size: 0.6rem;
  margin-top: 5px;
  flex-shrink: 0;
}
.cert-btn { align-self: flex-start; }

/* CTA BAND */
.cta-band {
  position: relative; padding: 120px 0; overflow: hidden;
  border-top: 1px solid var(--border);
}
.cta-band__glow {
  position: absolute; width: 800px; height: 500px;
  top: 50%; left: 50%; transform: translate(-50%,-50%);
  background: radial-gradient(ellipse, rgba(124,111,255,0.1) 0%, transparent 70%);
  filter: blur(60px); pointer-events: none;
}
.cta-band__inner {
  position: relative; text-align: center;
  display: flex; flex-direction: column; align-items: center; gap: 40px;
}

/* RESPONSIVE */
@media (max-width: 1024px) {
  .expertise-list { grid-template-columns: repeat(2,1fr); }
  .strip-grid { grid-template-columns: 1fr 1fr; min-height: auto; }
